{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run seed)",
      "Bash(npm run import)",
      "Bash(npm run scan:alerts)",
      "Bash(npm run db:push)",
      "Bash(npm run db:backup)",
      "Bash(npm run generate:types)",
      "Bash(npm run lint)",
      "Bash(npx tsc:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)"
    ],
    "ask": [
      "Bash(npm run db:restore:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(dropdb:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(DROP SCHEMA:*)"
    ]
  }
}
