# injector.world — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.

# --- Database (required) ---
# Local dev points at your Windows Postgres. Production swaps to DigitalOcean Managed Postgres.
DATABASE_URI=postgres://postgres:CHANGE_ME@localhost:5432/injectors_world_dev
# Connection pool size (optional, default 4). Keep low on small instances.
DB_POOL_MAX=4

# --- Payload (required) ---
# Secret used to sign auth tokens. Generate a long random string for production.
# Rotating this logs everyone out.
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- Public site (required) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=injector.world
# Google Tag Manager container ID (optional). When set, the GTM snippet is injected site-wide.
# Create a container at tagmanager.google.com and add GA4, conversion, and remarketing tags inside GTM.
NEXT_PUBLIC_GTM_ID=

# --- Seed admin (optional) ---
# Used by scripts/seed.ts to create the first admin user.
# Defaults: admin@injector.world / changeme.
SEED_ADMIN_EMAIL=admin@injector.world
SEED_ADMIN_PASSWORD=changeme

# --- Email (optional: bookings + newsletter) ---
# Leads save to the Bookings collection regardless. Booking emails + newsletter
# emails require RESEND_API_KEY. Leave blank to keep email off (console log only).
RESEND_API_KEY=
# Where admin booking notifications go.
ADMIN_EMAIL=

# --- Newsletter (Phase 10) ---
# From-address for newsletter emails. Domain must be verified on Resend.
NEWSLETTER_FROM=newsletter@injector.world
# Physical mailing address required by CAN-SPAM in every email footer.
# CRITICAL: Replace with a real, deliverable mailing address before sending any
# email to real subscribers. CAN-SPAM §7(a)(5) requires a valid physical postal
# address. Using a placeholder violates federal law and can result in fines.
NEWSLETTER_ADDRESS=Your Company Name, 123 Main St, Suite 100, City TX 77001

# --- Mapbox (Phase 16) ---
# Two tokens: one server-side (geocoding), one client-side (map rendering).
# Both can be the same token if it is URL-restricted to your domain. Keep them
# separate in production so the server token never leaks to the browser bundle.
#
# NEXT_PUBLIC_MAPBOX_TOKEN — rendered in the browser for Mapbox GL map tiles.
#   Restrict this token to your domain in the Mapbox console (URL allowlist).
#   Without this token the map shows a "Map unavailable" placeholder gracefully.
# MAPBOX_TOKEN — server-side only (geocoding via lib/geocode.ts). Never exposed.
#   Free tier: 100k geocode requests/month. Set GEOCODER=mapbox to activate.
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# --- Search geocoding (Phase 5 / Phase 16) ---
# Turns a typed location into coordinates for radius search. Swappable provider.
# Phase 16 decision: default is now "mapbox" (required for production anyway).
# Nominatim is acceptable for local development only (see policy note below).
#   Policy: <=1 req/sec, must set a real User-Agent. Prohibits commercial use.
#
# Set GEOCODER=nominatim + GEOCODER_USER_AGENT to fall back to Nominatim in dev.
GEOCODER=mapbox
GEOCODER_USER_AGENT=injector.world/1.0 (https://injector.world)
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/search

# --- Media storage (Phase 7) ---
# Admin/dashboard uploads (the Media collection) go to S3-compatible object
# storage so they persist across deploys/restarts. Leave these BLANK to fall
# back to local-disk storage for dev (a fresh clone runs with no keys).
#
# Currently Cloudflare R2 (free tier, zero egress). Moving to DigitalOcean
# Spaces later is an ENV-ONLY swap: replace the six values below with the DO
# Spaces ones (endpoint https://nyc3.digitaloceanspaces.com, region nyc3, etc).
# The code in lib/storage.ts does not change.
#
# Cloudflare R2 setup (founder): create a bucket, make a bucket-scoped S3 API
# token (Access Key ID + Secret), and enable public access (the managed
# pub-xxxx.r2.dev URL, or attach a custom domain). R2 needs NO per-object ACL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# S3 API endpoint (private). Build from the account id:
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# Public domain that serves the files (managed r2.dev URL or a custom domain).
# Public file URLs are built from this, NOT from the private S3 endpoint.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# --- Rate limiting (Phase 12: multi-instance) ---
# Connect to a managed Redis instance BEFORE scaling to >1 app instance.
# Without Redis, rate limits are per-process (in-memory Map) and not shared
# across instances — a single attacker can bypass limits by hitting different pods.
# DigitalOcean Managed Redis: ~$15/mo. See docs/DECISIONS.md Phase 12 note.
# Code hook in lib/rate-limit.ts is ready; Redis integration pending REDIS_URL.
REDIS_URL=

# --- Proxy trust (H2/H3 security) ---
# Number of trusted reverse-proxy hops between the internet and this process.
# Railway and DigitalOcean App Platform: 1 (they add exactly one hop).
# lib/rate-limit.ts reads the RIGHTMOST X-Forwarded-For entry (index [len - count])
# to prevent clients from spoofing their IP and bypassing rate limits.
# IMPORTANT: your host platform must strip (or override) any client-supplied
# X-Forwarded-For headers; otherwise attackers can pad the list to shift the index.
# Adjust if you add an additional proxy layer (e.g. Cloudflare + DO = 2).
TRUSTED_PROXY_COUNT=1

# --- CAPTCHA / bot protection (HD1) ---
# Cloudflare Turnstile protects public write endpoints (booking requests, claim forms).
# Setup: https://dash.cloudflare.com → Turnstile → Add site
#   - TURNSTILE_SECRET_KEY: server-side secret (never expose to client)
#   - NEXT_PUBLIC_TURNSTILE_SITE_KEY: widget site key (safe to expose; used in the browser widget)
# In development without these keys, CAPTCHA verification is skipped automatically.
# In production without TURNSTILE_SECRET_KEY, all submissions are blocked (fail-safe).
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Error monitoring (Phase 12) ---
# Sentry DSN for production error tracking. Leave blank to disable.
# Setup: npm install @sentry/nextjs, then run npx @sentry/wizard@latest -i nextjs
SENTRY_DSN=
