# --- Database ---
# Local dev points at your Windows Postgres. Production swaps to DigitalOcean Managed Postgres.
DATABASE_URI=postgres://postgres:CHANGE_ME@localhost:5432/injectors_world_dev

# --- Payload ---
# Secret used to sign auth tokens. Generate a long random string for production.
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- Public ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=injector.world

# --- Seed admin ---
# Used by scripts/seed.ts to create the first admin user.
SEED_ADMIN_EMAIL=admin@injector.world
SEED_ADMIN_PASSWORD=changeme
