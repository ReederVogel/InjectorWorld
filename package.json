{
  "name": "injectors-world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "devsafe": "rimraf .next && next dev",
    "build": "tsx scripts/db-push.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "payload": "payload",
    "db:push": "tsx scripts/db-push.ts",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "import": "tsx --env-file=.env.local scripts/import-providers.ts",
    "scan:alerts": "tsx --env-file=.env.local scripts/scan-data-alerts.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-seo": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@types/leaflet": "^1.9.21",
    "csv-parse": "^6.2.1",
    "framer-motion": "^12.40.0",
    "graphql": "^16.9.0",
    "leaflet": "^1.9.4",
    "next": "~15.4.11",
    "next-themes": "^0.4.3",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sharp": "0.32.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "~15.4.11",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
