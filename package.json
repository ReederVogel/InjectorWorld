{
  "name": "injectors-world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "devsafe": "rimraf .next && next dev",
    "build": "tsx scripts/run-pre-push-migrations.ts && tsx scripts/db-push.ts && tsx scripts/run-migrations.ts && tsx scripts/setup-search-indexes.ts && cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "payload": "payload",
    "db:push": "tsx scripts/db-push.ts",
    "db:backup": "tsx --env-file=.env.local scripts/db-backup.ts",
    "db:restore": "tsx --env-file=.env.local scripts/db-restore.ts",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "import": "tsx --env-file=.env.local scripts/import-providers.ts",
    "import:reviews": "tsx --env-file=.env.local scripts/import-reviews.ts",
    "scan:alerts": "tsx --env-file=.env.local scripts/scan-data-alerts.ts",
    "scan:pages": "tsx --env-file=.env.local scripts/scan-pages.ts",
    "db:wipe": "tsx --env-file=.env.local scripts/wipe-data.ts",
    "set:live": "tsx --env-file=.env.local scripts/set-live-markets.ts",
    "seed:brands": "tsx --env-file=.env.local scripts/seed-brands.ts",
    "setup:search": "tsx --env-file=.env.local scripts/setup-search-indexes.ts",
    "notify:golive": "tsx --env-file=.env.local scripts/notify-go-live.ts",
    "seed:zips": "tsx --env-file=.env.local scripts/seed-zips.ts",
    "drip:index": "tsx --env-file=.env.local scripts/drip-index.ts",
    "fix:audit": "node --env-file=.env.local scripts/audit-data-pre-deploy.mjs",
    "fix:zip": "node --env-file=.env.local scripts/fix-clinic-locations-from-zip.mjs",
    "fix:names": "node --env-file=.env.local scripts/cleanup-bad-clinic-names.mjs",
    "fix:seed": "node --env-file=.env.local scripts/delete-seed-providers.mjs",
    "fix:ziplocts": "node --env-file=.env.local scripts/cleanup-zip-locations.mjs",
    "fix:slugs": "node --env-file=.env.local scripts/migrate-city-slugs-production.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-seo": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "@payloadcms/ui": "^3.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "csv-parse": "^6.2.1",
    "framer-motion": "^12.40.0",
    "geojson": "^0.5.0",
    "graphql": "^16.9.0",
    "gsap": "^3.15.0",
    "mapbox-gl": "^3.25.0",
    "next": "~15.4.11",
    "next-themes": "^0.4.3",
    "payload": "^3.0.0",
    "pg": "8.13.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.1.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sharp": "0.32.6",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "~15.4.11",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
